  <script src="https://unpkg.com/typed.js@2.1.0/dist/typed.umd.js"></script>
  <style>
    * {
      scroll-behavior: smooth;
    }
    body {
      @apply bg-slate-900 text-gray-200;
      font-family: "popples", sans-serif;
    }
    .active {
      @apply text-cyan-400;
    }
    .btn-box {
      @apply px-4 py-2 bg-cyan-400 text-slate-900 rounded transition hover:bg-cyan-300 flex items-center gap-2 font-semibold;
    }
    .project-btn {
      @apply px-4 py-2 rounded transition flex items-center gap-2;
    }
    .project-btn.outline {
      @apply border border-cyan-400 text-cyan-400 hover:bg-cyan-400 hover:text-slate-900;
    }
    .project-btn.primary {
      @apply bg-cyan-400 text-slate-900 hover:bg-cyan-300;
    }
    .tech-badge {
      @apply px-3 py-1 bg-slate-800 text-cyan-400 rounded-full text-sm;
    }
    .category-dot {
      @apply w-2 h-2 rounded-full;
    }
    .category-dot.green {
      @apply bg-green-400;
    }
    .category-dot.purple {
      @apply bg-purple-400;
    }
    .learning-badge {
      @apply px-3 py-2 bg-slate-800 text-cyan-400 rounded-lg text-sm;
    }
  </style>
</head>

<body class="bg-slate-900 text-gray-200">
